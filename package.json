{
  "name": "uigen",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--require ./node-compat.cjs' next dev --turbopack",
    "dev:daemon": "NODE_OPTIONS='--require ./node-compat.cjs' next dev --turbopack > logs.txt 2>&1 & echo 'Server started, writing logs to logs.txt'",
    "build": "NODE_OPTIONS='--require ./node-compat.cjs' next build",
    "start": "NODE_OPTIONS='--require ./node-compat.cjs' next start",
    "setup": "npm install && npx prisma generate && prisma migrate dev",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "1.2.12",
    "@prisma/client": "^6.10.1",
    "ai": "4.3.16",
    "clsx": "^2.1.1",
    "jose": "^6.0.11",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^4.5.2",
    "eslint": "9.29.0",
    "eslint-config-next": "15.3.4",
    "prisma": "^6.10.1",
    "typescript": "^5"
  }
}
